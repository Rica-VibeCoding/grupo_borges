#!/usr/bin/env bash
# tara-codex — wrapper de observabilidade pra `codex exec`.
#
# Executa `codex exec --json` e relaya cada linha JSONL pra
# POST /api/codex-events do cockpit. Emite eventos de lifecycle
# (started/completed/failed) antes/depois do exec.
#
# Uso (substitui `nohup codex exec ... &` no workflow do Daniel):
#   tara-codex --delegator daniel -C /home/clawd/repos/grupo_borges "<prompt>"
#
# Args extras (após `--`) passam direto pro `codex exec`.
# Flags lidas pelo wrapper:
#   --delegator <slug>   identifica quem disparou (default: daniel)
#   --cockpit-url <url>  endpoint /api/codex-events
#   --resume-last        reusa thread_id capturada do último run desse
#                        delegator (se < 12h); senão segue fresh e avisa
#   --fresh              no-op explícito — default é fresh
#
# Defaults:
#   COCKPIT_URL=http://127.0.0.1:8000
#   DELEGATOR=daniel (se -d/--delegator não passado)
#
# Thread store: ~/.tara/threads/<delegator>.txt — gravada quando o evento
# JSONL `thread.started` é observado. Quem decide --resume-last é o
# Daniel-CC ao montar o comando, não o wrapper.
#
# NÃO commitar prompts com segredos — payload passa por scrub no backend
# mas evita expor no log local.

set -euo pipefail

COCKPIT_URL="${COCKPIT_URL:-http://127.0.0.1:8000}"
DELEGATOR="${TARA_DELEGATOR:-daniel}"
CODEX_BIN="${CODEX_BIN:-codex}"
THREAD_DIR="${TARA_THREAD_DIR:-${HOME}/.tara/threads}"
THREAD_MAX_AGE=43200  # 12h em segundos

RESUME_LAST=0
CODEX_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -d|--delegator)
      DELEGATOR="$2"; shift 2 ;;
    --cockpit-url)
      COCKPIT_URL="$2"; shift 2 ;;
    --resume-last)
      RESUME_LAST=1; shift ;;
    --fresh)
      shift ;;
    --)
      shift; CODEX_ARGS+=("$@"); break ;;
    *)
      CODEX_ARGS+=("$1"); shift ;;
  esac
done

if [[ ${#CODEX_ARGS[@]} -eq 0 ]]; then
  echo "uso: tara-codex [--delegator <slug>] [--resume-last] -- <args do codex exec>" >&2
  echo "ou:  tara-codex [--delegator <slug>] [--resume-last] <args do codex exec>" >&2
  exit 2
fi

mkdir -p "$THREAD_DIR"
THREAD_FILE="$THREAD_DIR/${DELEGATOR}.txt"

RESUME_ARGS=()
if [[ "$RESUME_LAST" -eq 1 ]]; then
  if [[ -f "$THREAD_FILE" ]]; then
    age=$(( $(date +%s) - $(stat -c %Y "$THREAD_FILE") ))
    thread_id=$(<"$THREAD_FILE")
    if [[ -n "$thread_id" && "$age" -lt "$THREAD_MAX_AGE" ]]; then
      RESUME_ARGS+=(--resume "$thread_id")
      echo "[tara-codex] retomando thread $thread_id (--resume-last, idade ${age}s)" >&2
    else
      echo "[tara-codex] --resume-last ignorado: thread em $THREAD_FILE tem $((age/3600))h (>12h) ou vazia" >&2
    fi
  else
    echo "[tara-codex] --resume-last ignorado: sem thread anterior em $THREAD_FILE" >&2
  fi
fi

# DS-69 — modelo escolhido pelo Rica no cockpit. Se o chamador NÃO passou
# `-m/--model`, busca o `state_model` persistido da Tara e injeta `-m <raw>`.
# Explícito da linha de comando sempre vence. De-para canônico→cru espelha
# `apps/api/services/tmux_driver.py:_CODEX_MODEL_MAP` (fonte única lá).
codex_raw_model() {
  case "$1" in
    codex-gpt-5-5)      echo "gpt-5.5" ;;
    codex-gpt-5-4)      echo "gpt-5.4" ;;
    codex-gpt-5-4-mini) echo "gpt-5.4-mini" ;;
    codex-gpt-5-3-codex) echo "gpt-5.3-codex" ;;
    codex-gpt-5-2)      echo "gpt-5.2" ;;
    *) echo "" ;;
  esac
}

caller_set_model=0
for arg in "${CODEX_ARGS[@]}"; do
  case "$arg" in
    -m|--model|-m=*|--model=*) caller_set_model=1; break ;;
  esac
done

if [[ "$caller_set_model" -eq 0 ]]; then
  persisted=$(curl -sS -m 4 "${COCKPIT_URL}/api/agents/tara" 2>/dev/null \
    | jq -r '.state_model // empty' 2>/dev/null || true)
  raw=$(codex_raw_model "$persisted")
  if [[ -n "$raw" ]]; then
    CODEX_ARGS=(-m "$raw" "${CODEX_ARGS[@]}")
    echo "[tara-codex] modelo do cockpit: $persisted → -m $raw" >&2
  fi
fi

post_event() {
  local kind="$1"
  local body="$2"
  curl -sS -m 4 -X POST "${COCKPIT_URL}/api/codex-events" \
    -H "Content-Type: application/json" \
    -d "$(jq -nc \
      --arg kind "$kind" \
      --arg delegator "$DELEGATOR" \
      --arg body "$body" \
      '{kind: $kind, delegator_agent_slug: $delegator, target_agent_slug: "tara", payload: ($body | fromjson? // {note: $body})}')" \
    > /dev/null || true
}

post_raw_jsonl() {
  local raw="$1"
  local kind
  kind=$(echo "$raw" | jq -r '.type // empty' 2>/dev/null || true)
  if [[ -z "$kind" ]]; then return; fi
  curl -sS -m 4 -X POST "${COCKPIT_URL}/api/codex-events" \
    -H "Content-Type: application/json" \
    -d "$(jq -nc \
      --arg kind "codex.$kind" \
      --arg delegator "$DELEGATOR" \
      --arg raw "$raw" \
      '{kind: $kind, delegator_agent_slug: $delegator, target_agent_slug: "tara", raw_jsonl: $raw, payload: ($raw | fromjson)}')" \
    > /dev/null || true
}

started_at=$(date +%s)
post_event "tara.exec.started" "{\"started_at\":$started_at,\"argv\":$(printf '%s\n' "${CODEX_ARGS[@]}" | jq -R . | jq -sc .)}"

set +e
"$CODEX_BIN" exec --json "${RESUME_ARGS[@]}" "${CODEX_ARGS[@]}" | tee /dev/stderr | while IFS= read -r line; do
  # Captura thread_id pra próximo --resume-last.
  if [[ "$line" == *'"thread.started"'* ]]; then
    tid=$(printf '%s' "$line" | jq -r '.thread_id // empty' 2>/dev/null || true)
    if [[ -n "$tid" ]]; then
      printf '%s' "$tid" > "$THREAD_FILE"
    fi
  fi
  post_raw_jsonl "$line"
done
exit_code=${PIPESTATUS[0]}
set -e

finished_at=$(date +%s)
duration=$((finished_at - started_at))

if [[ "$exit_code" -eq 0 ]]; then
  post_event "tara.exec.completed" "{\"exit_code\":0,\"duration_s\":$duration}"
else
  post_event "tara.exec.failed" "{\"exit_code\":$exit_code,\"duration_s\":$duration}"
fi

exit "$exit_code"
