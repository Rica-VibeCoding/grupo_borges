# grupo_borges API — env vars de exemplo
# Copiar pra .env (gitignored) e ajustar pro ambiente local.

# ---- Banco SQLite ----
GB_DB_PATH=./db/grupo_borges.db

# ---- Workspace path raiz (onde moram os 6 agentes) ----
# Em dev local (PC Windows):
GB_WORKSPACES_ROOT=C:/Users/RicardoBorges/Documents/dev/projetos/ze claude
# Em prod (VPS Linux):
# GB_WORKSPACES_ROOT=/home/clawd/repos/ze_claude

# ---- ~/.claude/projects (onde Claude Code grava JSONL) ----
# Em dev (PC):
GB_CLAUDE_PROJECTS_DIR=C:/Users/RicardoBorges/.claude/projects
# Em prod (VPS):
# GB_CLAUDE_PROJECTS_DIR=/home/clawd/.claude/projects

# ---- Auth (dev only) ----
# Defina como 1 pra bypassar identity headers em loopback (127.0.0.1)
GB_DEV_BYPASS_AUTH=1

# ---- Token cross-skill (futuro: Pavan-CC autorizado a chamar /hooks sem identity header) ----
# GB_HOOK_BEARER_TOKEN=
